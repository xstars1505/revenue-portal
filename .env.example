NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key

# Google Drive importer. Keep every value server-only.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/drive/callback
# Generate with a password manager; Vercel sends it to the daily cron route.
CRON_SECRET=

# Development only. Local password login is disabled in production.
DEMO_PASSWORD=
